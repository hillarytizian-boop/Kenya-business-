# ============================================
# 🔒 BUSINESS HUB KENYA - ENVIRONMENT VARIABLES
# ============================================
# ❌ NEVER COMMIT THIS FILE WITH REAL VALUES
# ✅ Copy to .env and fill in your credentials
# ============================================

# ===== APP =====
NODE_ENV=production
PORT=3001
APP_URL=https://yourdomain.com
API_PREFIX=/api/v1

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_DATABASE=business_hub_kenya
DB_SSL_MODE=require

# ===== REDIS =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_DB=0

# ===== JWT (Generate strong secrets) =====
# Generate: openssl rand -base64 32
JWT_SECRET=GENERATE_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=GENERATE_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ===== M-PESA =====
MPESA_CONSUMER_KEY=YOUR_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_MPESA_CONSUMER_SECRET
MPESA_PASSKEY=YOUR_MPESA_PASSKEY
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-backend.com/api/v1/payments/mpesa/callback

# ===== STORAGE (Cloudflare R2) =====
S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY
S3_SECRET_KEY=YOUR_R2_SECRET_KEY
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ===== SECURITY =====
ENCRYPTION_KEY=GENERATE_32_CHAR_ENCRYPTION_KEY
CSRF_SECRET=GENERATE_CSRF_SECRET
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
WEBHOOK_SECRET=GENERATE_WEBHOOK_SECRET

# ===== EMAIL =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com

# ===== SMS (Africa's Talking) =====
AFRICASTALKING_API_KEY=YOUR_AFRICASTALKING_KEY
AFRICASTALKING_USERNAME=sandbox

# ===== ADMIN =====
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=GENERATE_STRONG_ADMIN_PASSWORD

# ===== CORS =====
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# ===== LOGGING =====
LOG_LEVEL=info
SENTRY_DSN=YOUR_SENTRY_DSN

# ============================================
# 🔐 GENERATE SECURE SECRETS:
# openssl rand -base64 32
# openssl rand -hex 32
# ============================================
